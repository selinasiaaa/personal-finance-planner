const mongoose = require('mongoose');
const MarketData = require('../models/MarketData');
const { fetchMarketInsights } = require('../services/financialApi');

const buildRiskSub = (riskLevel) => {
  switch ((riskLevel || '').toLowerCase()) {
    case 'low':
      return 'Use a conservative stance';
    case 'moderate':
      return 'Monitor volatility';
    case 'high':
      return 'Tighten risk controls';
    default:
      return '';
  }
};

const buildRecommendations = (summary = {}, news = []) => {
  const trend = (summary.trend || '').toLowerCase();
  const riskLevel = (summary.riskLevel || '').toLowerCase();
  const topPerformer = summary.topPerformer || 'the leading sector';
  const performance = summary.performanceReading || '0%';
  const firstHeadline = news[0]?.title || 'the latest market updates';

  const recommendations = [];

  if (trend === 'bullish') {
    recommendations.push({
      icon: 'bi-graph-up-arrow',
      title: 'Ride the Trend',
      text: `Market sentiment is positive. Consider reviewing growth exposure around ${topPerformer}.`,
      warn: false,
    });
  } else if (trend === 'bearish') {
    recommendations.push({
      icon: 'bi-shield-exclamation',
      title: 'Protect Capital',
      text: `Momentum is weaker. Focus on capital preservation and watch ${firstHeadline}.`,
      warn: true,
    });
  } else {
    recommendations.push({
      icon: 'bi-easel2',
      title: 'Stay Balanced',
      text: `The market is neutral. Keep a balanced allocation and monitor ${topPerformer}.`,
      warn: false,
    });
  }

  recommendations.push({
    icon: 'bi-bar-chart-line',
    title: 'Review Allocation',
    text: `Compare your portfolio against ${topPerformer} and recent performance at ${performance}.`,
    warn: false,
  });

  recommendations.push({
    icon: 'bi-newspaper',
    title: 'Read the Latest News',
    text: `Check the latest headline: ${firstHeadline}. Use it to confirm the current market direction.`,
    warn: false,
  });

  if (riskLevel === 'high') {
    recommendations.push({
      icon: 'bi-exclamation-triangle',
      title: 'Reduce Risk',
      text: 'Volatility is elevated. Consider smaller position sizes and tighter stop-loss planning.',
      warn: true,
    });
  } else if (riskLevel === 'moderate') {
    recommendations.push({
      icon: 'bi-shield-check',
      title: 'Monitor Volatility',
      text: 'Risk is moderate. Stay alert to price swings and rebalance if needed.',
      warn: false,
    });
  } else {
    recommendations.push({
      icon: 'bi-check-circle',
      title: 'Stay Disciplined',
      text: 'Risk is low. Continue with your plan and keep an eye on any macro changes.',
      warn: false,
    });
  }

  return recommendations.slice(0, 4);
};

const normalizeMarketData = (source = {}) => {
  const summary = source.summary || {};
  const news = Array.isArray(source.news) ? source.news : [];
  
  // 1. Safely extract the new charts data, or provide empty arrays as a fallback
  const charts = source.charts || { sp500Trend: [], sectorPerformance: [] };
  
  const trend = summary.trend || source.trend || 'Neutral';
  const topPerformer = summary.topPerformer || source.topPerformer || 'Market Leaders';
  const performance = summary.performanceReading || source.performance || source.sp500 || '—';
  const riskLevel = summary.riskLevel || source.riskLevel || 'Moderate';

  return {
    trend,
    sp500: source.sp500 || performance,
    topPerformer,
    performance,
    riskLevel,
    riskSub: buildRiskSub(riskLevel),
    news,
    charts, // 2. Add charts to the final payload sent to the frontend!
    recommendations: buildRecommendations({ trend, topPerformer, performanceReading: performance, riskLevel }, news),
    summary: {
      trend,
      topPerformer,
      performanceReading: performance,
      riskLevel,
    },
    lastFetched: source.lastFetched || new Date().toISOString(),
  };
};

const canUseCache = () => mongoose.connection.readyState === 1;

const saveMarketCache = async (dashboardData) => {
  if (!canUseCache()) {
    return;
  }

  await MarketData.findOneAndUpdate(
    {},
    {
      summary: dashboardData.summary,
      news: dashboardData.news,
      charts: dashboardData.charts, // 3. Save the charts to your MongoDB cache
      lastFetched: dashboardData.lastFetched,
    },
    { upsert: true, new: true },
  );
};

const getCachedMarketData = async () => {
  if (!canUseCache()) {
    return null;
  }

  const cached = await MarketData.findOne().lean();
  return cached ? normalizeMarketData(cached) : null;
};

const getMarketInsights = async (req, res) => {
  try {
    const apiData = await fetchMarketInsights();
    
    if (apiData) {
      const dashboardData = normalizeMarketData(apiData);
      await saveMarketCache(dashboardData);

      return res.status(200).json({ success: true, data: dashboardData, source: 'finnhub' });
    }

    const cachedData = await getCachedMarketData();

    if (cachedData) {
      return res.status(200).json({ success: true, data: cachedData, source: 'cache' });
    }

    return res.status(503).json({ success: false, message: 'No market insights available yet.' });

  } catch (error) {
    console.error(`Controller Error: ${error.message}`);
    res.status(500).json({ success: false, message: 'Server Error' });
  }
};

module.exports = { getMarketInsights };