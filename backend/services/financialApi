const fetchMarketInsights = async () => {
  const apiKey = process.env.FINNHUB_API_KEY;
  
  if (!apiKey) {
    console.warn("No Finnhub API key found, using fallback data.");
    return getFallbackMarketInsights();
  }

  try {
    // 1. Fetch S&P 500 (SPY) for summary
    const quoteRes = await fetch(`https://finnhub.io/api/v1/quote?symbol=SPY&token=${apiKey}`);
    const quoteData = await quoteRes.json();
    const percentChange = quoteData.dp;
    const isPositive = percentChange >= 0;

    // 2. Fetch General Market News
    const newsRes = await fetch(`https://finnhub.io/api/v1/news?category=general&token=${apiKey}`);
    const newsData = await newsRes.json();
    const formattedNews = newsData.slice(0, 3).map(item => {
      const hoursAgo = Math.max(1, Math.floor((Date.now() / 1000 - item.datetime) / 3600));
      return { title: item.headline, source: item.source, timeLabel: `${hoursAgo} hours ago`, link: item.url };
    });

    // 3. NEW: Fetch 6 Months of Historical Data for the Line Chart
    const toDate = Math.floor(Date.now() / 1000);
    const fromDate = toDate - (6 * 30 * 24 * 60 * 60); // Roughly 6 months ago
    const candleRes = await fetch(`https://finnhub.io/api/v1/stock/candle?symbol=SPY&resolution=M&from=${fromDate}&to=${toDate}&token=${apiKey}`);
    const candleData = await candleRes.json();

    let sp500History = [];
    if (candleData.s === 'ok') {
      sp500History = candleData.c.map((price, index) => ({
        month: new Date(candleData.t[index] * 1000).toLocaleString('default', { month: 'short' }),
        price: parseFloat(price.toFixed(2))
      }));
    }

    // 4. NEW: Fetch Real-Time Sector Performance for the Bar Chart (Using major ETFs)
    const sectors = [
      { name: 'Tech', symbol: 'XLK' },
      { name: 'Health', symbol: 'XLV' },
      { name: 'Finance', symbol: 'XLF' },
      { name: 'Energy', symbol: 'XLE' },
      { name: 'Consumer', symbol: 'XLY' }
    ];

    // Fetch all 5 sector quotes at the exact same time
    const sectorPromises = sectors.map(async (sector) => {
      const res = await fetch(`https://finnhub.io/api/v1/quote?symbol=${sector.symbol}&token=${apiKey}`);
      const data = await res.json();
      return { sector: sector.name, performance: data.dp };
    });
    const sectorPerformanceData = await Promise.all(sectorPromises);

    // 5. Return everything packaged perfectly for your UI
    return {
      summary: {
        trend: isPositive ? 'Bullish' : 'Bearish',
        topPerformer: 'S&P 500 (SPY)',
        performanceReading: `${isPositive ? '+' : ''}${percentChange.toFixed(2)}%`,
        riskLevel: Math.abs(percentChange) > 2 ? 'High' : 'Moderate' 
      },
      news: formattedNews,
      charts: {
        sp500Trend: sp500History,
        sectorPerformance: sectorPerformanceData
      }
    };

  } catch (error) {
    console.error("Finnhub API Error:", error.message);
    return getFallbackMarketInsights();
  }
};
module.exports = { fetchMarketInsights };