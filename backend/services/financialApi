// No need for GoogleGenerativeAI anymore!

const getFallbackMarketInsights = () => ({
  summary: {
    trend: 'Bullish',
    topPerformer: 'Tech Stocks',
    performanceReading: '+2.5%',
    riskLevel: 'Moderate',
  },
  news: [
    { title: 'Tech Stocks Rally as AI Innovation Continues to Drive Growth', source: 'Financial Times', timeLabel: '2 hours ago', link: '#' },
    { title: 'S&P 500 Reaches New Heights Amid Strong Economic Data', source: 'Bloomberg', timeLabel: '4 hours ago', link: '#' },
    { title: 'Federal Reserve Signals Cautious Approach to Interest Rate Changes', source: 'Reuters', timeLabel: '6 hours ago', link: '#' },
  ],
});

const fetchFinnhubMarketInsights = async () => {
  const apiKey = process.env.FINNHUB_API_KEY;
  
  if (!apiKey) {
    console.warn("No Finnhub API key found, using fallback data.");
    return getFallbackMarketInsights();
  }

  try {
    // 1. Fetch S&P 500 (SPY) data to calculate the market summary
    const quoteRes = await fetch(`https://finnhub.io/api/v1/quote?symbol=SPY&token=${apiKey}`);
    const quoteData = await quoteRes.json();
    
    const percentChange = quoteData.dp; // Daily percentage change
    const isPositive = percentChange >= 0;

    // 2. Fetch the latest general market news
    const newsRes = await fetch(`https://finnhub.io/api/v1/news?category=general&token=${apiKey}`);
    const newsData = await newsRes.json();

    // 3. Format the top 3 news items to match your UI's structure
    const formattedNews = newsData.slice(0, 3).map(item => {
      // Finnhub returns timestamps in seconds. Calculate hours ago:
      const hoursAgo = Math.max(1, Math.floor((Date.now() / 1000 - item.datetime) / 3600));
      
      return {
        title: item.headline,
        source: item.source,
        timeLabel: `${hoursAgo} hours ago`,
        link: item.url
      };
    });

    // 4. Return the fully structured, real-time data
    return {
      summary: {
        trend: isPositive ? 'Bullish' : 'Bearish',
        topPerformer: 'S&P 500 (SPY)',
        performanceReading: `${isPositive ? '+' : ''}${percentChange.toFixed(2)}%`,
        // If the market swings more than 2% in a day, flag it as High risk
        riskLevel: Math.abs(percentChange) > 2 ? 'High' : 'Moderate' 
      },
      news: formattedNews
    };

  } catch (error) {
    console.error("Finnhub API Error:", error.message);
    console.warn("Using fallback market data");
    return getFallbackMarketInsights();
  }
};

// Export the new function
module.exports = { fetchMarketInsights: fetchFinnhubMarketInsights };